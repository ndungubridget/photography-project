<link rel="alternate" title="oEmbed (JSON)" type="application/json+oembed" href="https://a-z-animals.com/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fa-z-animals.com%2Fanimals%2F" />
<link rel="alternate" title="oEmbed (XML)" type="text/xml+oembed" href="https://a-z-animals.com/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fa-z-animals.com%2Fanimals%2F&#038;format=xml" />
        <style>
        .getty.aligncenter {
            text-align: center;
        }
        .getty.alignleft {
            float: none;
            margin-right: 0;
        }
        .getty.alignleft > div {
            float: left;
            margin-right: 5px;
        }
        .getty.alignright {
            float: none;
            margin-left: 0;
        }
        .getty.alignright > div {
            float: right;
            margin-left: 5px;
        }
        </style>
        <style type="text/css">
			:root{
				--lasso-main: #00612b !important;
				--lasso-title: black !important;
				--lasso-button: #1c49c2 !important;
				--lasso-secondary-button: #ff9900 !important;
				--lasso-button-text: white !important;
				--lasso-background: white !important;
				--lasso-pros: #22baa0 !important;
				--lasso-cons: #e06470 !important;
			}
			
			
		</style>
