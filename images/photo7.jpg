var pitchConfig = {"growthbookClientKey":"sdk-pnoYM8RKKZJnWTx","growthbookScrollModalFlag":"az-scroll-modal","growthbookPostEoaFlag":"","scrollModalThreshold":"25","scrollModalStyle":"centered","siteUrl":"https:\/\/a-z-animals.com","postId":"42361","postSlug":"animals","pencilBar":{"enabled":false,"ctaText":null,"buttonText":null,"url":null},"previewParam":"fwp_pid","marketingPageBodyClass":"marketing-page","campaign":null,"thisSite":"azanimals","smartAssetUtmSource":"azanimals","tickers":[],"primaryTickers":"","pitcherApiUrl":"https:\/\/pitcher-api.flywheel-publishing.com","pitcherApiKey":"public_cae631d9ee1c2db310d169544cc5b830f377dc60d2251482","pitcherTrackingApiKey":"tracking_759e2937d3a8db03e7748730a38e90cc1eea15072be5ec84","pitcherLineupId":"01b611d6-bc6e-4bde-84d0-88c8480815b2","usePitcherApi":"1","pitches":[{"id":"68bf5ef7da607","name":"lemonade_pet_insurance","content":"<div class=\"container my-4\">\n<div class=\"card mx-auto tw-max-w-3xl tw-border-2\" style=\"background-color: #FFF5F0; border-color: #FF6B35; position: relative; cursor: pointer;\">\n<div class=\"card-body\" style=\"padding: 2.5rem 3.5rem !important;\">\n<div class=\"row align-items-center\">\n<div class=\"col-auto d-none d-md-block\" style=\"padding: 0 2rem;\"> <img decoding=\"async\" src=\"\/media\/dog.png\" alt=\"Dog with bandage and thermometer\" style=\"width: 180px;\" loading=\"lazy\"> <\/div>\n<div class=\"col\" style=\"padding-right: 1.5rem;\">\n<h4 class=\"mb-3 font-weight-bold\" style=\"color: #FF6B35; font-size: 1.5rem;\"><span style=\"color: #4169E1;\">\ud83d\udc3e<\/span> Pets Are Starting To Get Crazy Expensive<\/h4>\n<p class=\"mb-2\" style=\"color: #333; line-height: 1.5;\">One unexpected trip to the vet can cost $1,500, or more. Even for simple but common things like minor wounds, UTIs, even ear infections.<\/p>\n<p class=\"mb-3\" style=\"color: #333; line-height: 1.5;\">But, Lemonade has flipped pet insurance on it&#8217;s head and can cut these bills by 90%. With super fast everything. You can sign up in seconds, get paid in minutes, and save hundreds.<\/p>\n<p><a href=\"https:\/\/a-z-animals.com\/go\/impact\/pet-insurance\" class=\"btn text-white font-weight-bold stretched-link\" style=\"background-color: #FF6B35; border-color: #FF6B35; padding: 12px 24px; border-radius: 6px; display: inline-block;\" target=\"_blank\">See just how easy it is to save 90% on vet visits<\/a><\/div>\n<\/div>\n<p class=\"small font-italic mt-3 mb-0\" style=\"color: #888;\">*We may earn a commission if you sign up through this link, which helps us further the A-Z Animals mission to educate about the world&#8217;s species.<\/p>\n<\/div>\n<\/div>\n<\/div>\n","js":"","css":"","isHouseAd":false,"campaign":"lemonade-insurance","campaign_id":5564,"partner":"impact-radius","disclosure":""}],"subscriptionHandlerApiUrl":"https:\/\/a-z-animals.com\/workers\/subscribe"};
</script>
