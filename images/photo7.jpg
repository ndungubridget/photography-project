<style data-no-optimize="1" data-cfasync="false">
	.adthrive-ad {
		margin-top: 10px;
		margin-bottom: 10px;
		text-align: center;
		overflow-x: visible;
		clear: both;
		line-height: 0;
	}
	/* White Background For Mobile Sticky Video Player */
.adthrive-collapse-mobile-background {
background-color:white!important;
}
.adthrive-top-collapse-close > svg > * {
stroke: black;
font-family: sans-serif;
}



.adthrive-ad {
  clear: none;
}

.body_animal .adthrive-content,
.az-animals-index .adthrive-content {
  clear: both;
}

.adthrive-header,
.adthrive-sidebar-1 {
  margin: 0;
}

@media (min-width: 768px) {
  body.page-template-animals-by-letter .adthrive-content {
    flex: 0 0 33.333333%;
    max-width: 33.333333%;
  }
}

/* Fix for left aligned ads, 10/11/19 */
.adthrive-ad > div[id^='google_ads_iframe'] {
  display: block !important;
}

/* Fix for CLS video container not respecting site width */
.adthrive-device-desktop div[id^='cls-video-container'],
.adthrive-device-tablet div[id^='cls-video-container'] {
  min-width: unset !important;
  max-width: 600px;
  max-height: 400px;
  min-height: unset !important;
  margin: 10px auto;
}

.adthrive-sidebar.adthrive-stuck {
  margin-top: 100px;
}

body.page .adthrive-content {
  flex: 100%;
}

/* for sticky SB1-5 */
.adthrive-sticky-sidebar > div {
top: 75px!important;
}


.adthrive-stuck.adthrive-sticky.adthrive-sidebar, .adthrive-stuck.adthrive-sticky.adthrive-header {
top: 0.7rem!important;
}

/* Fix for left aligned ads */
.adthrive-ad-cls>div, .adthrive-ad-cls>iframe {
   flex-basis: auto!important;
}
</style>
